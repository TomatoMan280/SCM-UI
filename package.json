{
  "name": "silhouette-ui",
  "productName": "Silhouette",
  "description": "Silhouette Card Maker UI",
  "author": "Alan-Cha",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "install-deps": "export DEBIAN_FRONTEND=noninteractive && apt-get update && apt-get install -y -o Dpkg::Options::=\"--force-confdef\" -o Dpkg::Options::=\"--force-confnew\" python3-pip && python3 -m pip install click cloudscraper ezdxf filetype matplotlib mtg_parser pyyaml pillow requests natsort pydantic pypdfium2 split-image pyautogui --break-system-packages",
    "lint": "tsc --noEmit",
    "desktop:build": "npm run build && electron-builder",
    "desktop:build:win": "npm run build && electron-builder --win",
    "desktop:build:mac": "npm run build && electron-builder --mac",
    "desktop:build:linux": "npm run build && electron-builder --linux",
    "desktop:dev": "npm run build && electron ."
  },
  "build": {
    "appId": "com.alancha.silhouette",
    "directories": {
      "output": "release/"
    },
    "asar": true,
    "asarUnpack": [
      "src/silhouette-card-maker-main",
      "src/Library"
    ],
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "package.json",
      "src/silhouette-card-maker-main/**/*",
      "src/Library/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "adm-zip": "^0.5.17",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
