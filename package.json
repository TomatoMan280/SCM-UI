{
  "name": "silhouette-ui",
  "version": "1.0.5",
  "description": "Silhouette Card Maker UI",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "start": "NODE_ENV=production npx tsx server.ts",
    "build": "echo 'Using pre-built assets'",
    "dev": "NODE_ENV=production npx tsx server.ts",
    "lint": "echo 'Skipping lint'",
    "desktop:start": "npx esbuild server.ts --bundle --platform=node --format=esm --outfile=dist/server.js --external:express --external:multer --external:adm-zip --external:archiver --external:bignumber.js --external:@google/genai --external:vite && npx electron .",
    "desktop:build:win": "npx esbuild server.ts --bundle --platform=node --format=esm --outfile=dist/server.js --external:express --external:multer --external:adm-zip --external:archiver --external:bignumber.js --external:@google/genai --external:vite && npx electron-builder --win --x64"
  },
  "dependencies": {
    "@google/genai": "^1.52.0",
    "adm-zip": "^0.5.10",
    "archiver": "^6.0.1",
    "bignumber.js": "^9.1.2",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/archiver": "^6.0.2",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  },
  "build": {
    "appId": "com.tomatomandev.scmui",
    "productName": "Silhouette Card Maker UI",
    "directories": {
      "output": "dist-desktop"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Silhouette Card Maker"
    },
    "files": [
      "package.json",
      "main.js",
      "dist/**/*",
      "src/silhouette-card-maker-main/**/*"
    ],
    "asar": true
  }
}
